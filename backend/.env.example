# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://backfindr:backfindr_dev_pass@localhost:5432/backfindr

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-64-random-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8081"]

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=uploads
# Para produção com Cloudflare R2:
# STORAGE_BACKEND=r2
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=
# R2_PUBLIC_URL=

# ── Push Notifications (VAPID) ────────────────────────────────────────────────
# Gerar com: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_key, v.public_key)"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=admin@backfindr.com

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
ENVIRONMENT=development
DEBUG=true
