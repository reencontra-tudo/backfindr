# ─── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/backfindr

# ─── Autenticação JWT ─────────────────────────────────────────────────────────
SECRET_KEY=sua_chave_secreta_minimo_32_chars
ALGORITHM=HS256

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://backfindr.com
NEXT_PUBLIC_API_URL=https://backfindr.com

# ─── Mapbox ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# ─── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ─── Facebook OAuth ───────────────────────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ─── E-mail (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...

# ─── Cloudflare R2 (armazenamento de imagens) ─────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=backfindr-media
R2_PUBLIC_URL=https://pub-HASH.r2.dev

# ─── Web Push Notifications (VAPID) ──────────────────────────────────────────
# Gerar com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:suporte@backfindr.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── OpenAI (Assistente IA) ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-...

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Analytics (PostHog) ─────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# ─── Analytics (Google Analytics 4) ─────────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Segurança e automação ────────────────────────────────────────────────────
INTERNAL_API_KEY=chave_interna_para_crons
CRON_SECRET=chave_secreta_para_crons_vercel
MIGRATION_SECRET=chave_para_migrations_admin
ADMIN_IDS=uuid1,uuid2

# ─── Ambiente ─────────────────────────────────────────────────────────────────
NODE_ENV=production
ENVIRONMENT=production
BACKEND_API_URL=https://backfindr.com
